//Slow Solution
class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0){
		    int maxT = sc.nextInt();
            int maxN = sc.nextInt();
            int sumN = sc.nextInt();

            long ans = 0;
            int remaining = sumN;

            for (int i = 0; i < maxT && remaining > 0; i++) {
                int take = Math.min(maxN, remaining);
                ans += (long) take * take;
                remaining -= take;
            }

            System.out.println(ans);
		}

	}
}
